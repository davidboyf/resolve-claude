ANTHROPIC_API_KEY=your_anthropic_key_here

# AI Image Generation (choose one or both)
OPENAI_API_KEY=your_openai_key_here         # For DALL-E 3
FAL_KEY=your_fal_key_here                   # For Flux Schnell (fast, free tier at fal.ai)
REPLICATE_API_KEY=your_replicate_key_here   # Optional: Replicate models

# DaVinci Resolve paths (auto-detected on Mac, override if needed)
RESOLVE_SCRIPT_API=/Library/Application Support/Blackmagic Design/DaVinci Resolve/Developer/Scripting
RESOLVE_SCRIPT_LIB=/Applications/DaVinci Resolve/DaVinci Resolve.app/Contents/Libraries/Fusion/fusionscript.so
